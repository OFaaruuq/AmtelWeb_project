FLASK_SECRET_KEY=replace-with-a-long-random-public-secret
ANALYTICS_RETRY_SECONDS=30

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=amtelkom_analytics
MYSQL_USER=amtelkom_admin
MYSQL_PASSWORD=replace-with-strong-password
MYSQL_CONNECTION_TIMEOUT=3
ANALYTICS_IP_HASH_SALT=replace-with-the-same-private-salt

GEOLOCATION_ENABLED=true
GEOLOCATION_ENDPOINT=http://ip-api.com/json/{ip}

PUBLIC_RATE_LIMIT_PER_MINUTE=180
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
