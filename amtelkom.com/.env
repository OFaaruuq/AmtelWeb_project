FLASK_SECRET_KEY=replace-with-a-long-random-public-site-secret
ADMIN_APP_URL=http://127.0.0.1:5001
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
# Prefer ADMIN_PASSWORD_HASH in production. Generate with:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
ADMIN_PASSWORD_HASH=

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=amtelkom_analytics
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_CONNECTION_TIMEOUT=3

ANALYTICS_DAYS=30
ANALYTICS_IP_HASH_SALT=replace-this-with-a-private-random-salt
GEOLOCATION_ENABLED=true
GEOLOCATION_ENDPOINT=http://ip-api.com/json/{ip}
